{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yoloop Adapter Catalog",
  "type": "object",
  "required": ["schemaVersion", "adapters"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "command",
          "workerArgs",
          "criticArgs",
          "grandJuryArgs"
        ],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "command": { "type": "string" },
          "workerArgs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "criticArgs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "grandJuryArgs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
