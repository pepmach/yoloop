{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yoloop Critic Verdict",
  "type": "object",
  "required": [
    "schemaVersion",
    "taskId",
    "verdict",
    "summary",
    "checks",
    "gaps",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "taskId": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["approved", "rejected", "human_approval_required"]
    },
    "summary": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
